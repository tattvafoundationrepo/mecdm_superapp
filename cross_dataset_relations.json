{
  "$schema": "cross_dataset_relations_v1",
  "metadata": {
    "version": "1.0.0",
    "description": "Cross-dataset relationship definitions for MECDM tables",
    "notes": "These are the ONLY valid join paths. Do not assume relationships not defined here."
  },
  "hierarchies": {
    "administrative": {
      "description": "Meghalaya administrative hierarchy: State → District → Block → Village",
      "levels": [
        {
          "name": "state",
          "table": "states",
          "pk": "lgd_statecode"
        },
        {
          "name": "district",
          "table": "districts",
          "pk": "lgd_districtcode",
          "fk_to_parent": "lgd_statecode"
        },
        {
          "name": "subdistrict",
          "table": "subdistricts",
          "pk": "lgd_subdistrictcode",
          "fk_to_parent": "lgd_districtcode"
        },
        {
          "name": "village",
          "table": "villages_point",
          "pk": "lgd_villagecode",
          "fk_to_parent": "lgd_subdistrictcode"
        }
      ]
    },
    "master_reference": {
      "description": "Master reference hierarchy with LGD codes",
      "levels": [
        {
          "name": "district",
          "table": "master_districts",
          "pk": "district_code_lgd"
        },
        {
          "name": "block",
          "table": "master_blocks",
          "pk": "block_code_lgd",
          "fk_to_parent": "district_code_lgd"
        },
        {
          "name": "village",
          "table": "master_villages",
          "pk": "village_id",
          "fk_to_parent": "block_code_lgd"
        },
        {
          "name": "facility",
          "table": "master_health_facilities",
          "pk": "facility_id",
          "fk_to_parent": "block_code_lgd"
        }
      ]
    }
  },
  "relations": [
    {
      "id": "geo_to_master_district",
      "description": "Link geographic districts to master reference",
      "from": {
        "table": "districts",
        "column": "lgd_districtcode"
      },
      "to": {
        "table": "master_districts",
        "column": "district_code_lgd"
      },
      "cardinality": "one_to_one",
      "join_quality": "exact"
    },
    {
      "id": "master_blocks_to_districts",
      "description": "Link blocks to districts via LGD code",
      "from": {
        "table": "master_blocks",
        "column": "district_code_lgd"
      },
      "to": {
        "table": "master_districts",
        "column": "district_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact"
    },
    {
      "id": "master_villages_to_blocks",
      "description": "Link villages to blocks via LGD code",
      "from": {
        "table": "master_villages",
        "column": "block_code_lgd"
      },
      "to": {
        "table": "master_blocks",
        "column": "block_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact"
    },
    {
      "id": "master_hf_to_blocks",
      "description": "Link health facilities to blocks",
      "from": {
        "table": "master_health_facilities",
        "column": "block_code_lgd"
      },
      "to": {
        "table": "master_blocks",
        "column": "block_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact"
    },
    {
      "id": "village_indicators_to_master_blocks",
      "description": "Link monthly indicators to blocks for aggregation",
      "from": {
        "table": "village_indicators_monthly",
        "column": "block_code_lgd"
      },
      "to": {
        "table": "master_blocks",
        "column": "block_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact"
    },
    {
      "id": "village_indicators_to_master_districts",
      "description": "Link monthly indicators to districts for aggregation",
      "from": {
        "table": "village_indicators_monthly",
        "column": "district_code_lgd"
      },
      "to": {
        "table": "master_districts",
        "column": "district_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact"
    },
    {
      "id": "anganwadi_to_blocks",
      "description": "Link AWCs to blocks",
      "from": {
        "table": "anganwadi_centres",
        "column": "block_code"
      },
      "to": {
        "table": "master_blocks",
        "column": "block_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "requires_cast",
      "notes": "block_code may need BIGINT cast"
    },
    {
      "id": "health_facilities_to_blocks",
      "description": "Link health facilities to blocks",
      "from": {
        "table": "health_facilities",
        "column": "block_code"
      },
      "to": {
        "table": "master_blocks",
        "column": "block_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "requires_cast"
    },
    {
      "id": "mothers_by_lgd_district",
      "description": "Mother App pregnancies linked to master_districts via LGD district code (preferred join)",
      "from": {
        "table": "mothers",
        "column": "lgd_district_code"
      },
      "to": {
        "table": "master_districts",
        "column": "district_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact"
    },
    {
      "id": "mothers_by_geography",
      "description": "Mother App pregnancies linked to master_blocks via TEXT district/block names",
      "from": {
        "table": "mothers",
        "columns": [
          "district",
          "block"
        ]
      },
      "to": {
        "table": "master_blocks",
        "columns": [
          "district_name",
          "block_name"
        ]
      },
      "cardinality": "many_to_one",
      "join_quality": "fuzzy_text",
      "notes": "Use UPPER(TRIM()) for matching. Prefer mothers_by_lgd_district for the district level."
    },
    {
      "id": "mother_anc_visits_to_mothers",
      "description": "Long-form ANC visits to parent pregnancy (composite FK)",
      "from": {
        "table": "mother_anc_visits_flat",
        "columns": [
          "mother_id",
          "pregnancy_number"
        ]
      },
      "to": {
        "table": "mothers",
        "columns": [
          "mother_id",
          "pregnancy_number"
        ]
      },
      "cardinality": "many_to_one",
      "join_quality": "exact",
      "notes": "Enforced by FK fk_manc_mothers. Each pregnancy has up to 4 ANC visit rows (anc_visit_num 1–4)."
    },
    {
      "id": "mother_children_to_mothers",
      "description": "Per-child rows to parent pregnancy (composite FK)",
      "from": {
        "table": "mother_children",
        "columns": [
          "mother_id",
          "pregnancy_number"
        ]
      },
      "to": {
        "table": "mothers",
        "columns": [
          "mother_id",
          "pregnancy_number"
        ]
      },
      "cardinality": "many_to_one",
      "join_quality": "exact",
      "notes": "Enforced by FK fk_mchildren_mothers. Each pregnancy has up to 3 child rows (child_num 1–3)."
    },
    {
      "id": "anc_visits_by_geography",
      "description": "ANC visits linked by district/block TEXT names",
      "from": {
        "table": "anc_visits",
        "columns": [
          "district",
          "block"
        ]
      },
      "to": {
        "table": "master_blocks",
        "columns": [
          "district_name",
          "block_name"
        ]
      },
      "cardinality": "many_to_one",
      "join_quality": "fuzzy_text"
    },
    {
      "id": "nfhs_by_district",
      "description": "NFHS indicators by district name (text match)",
      "from": {
        "table": "nfhs_indicators",
        "column": "district"
      },
      "to": {
        "table": "master_districts",
        "column": "district_name"
      },
      "cardinality": "many_to_one",
      "join_quality": "fuzzy_text",
      "notes": "NFHS district names may differ slightly; normalize before join"
    },
    {
      "id": "geo_full_mapping_to_districts",
      "description": "Full mapping table for cross-level navigation",
      "from": {
        "table": "geo_full_mapping",
        "column": "district_code_lgd"
      },
      "to": {
        "table": "master_districts",
        "column": "district_code_lgd"
      },
      "cardinality": "many_to_one",
      "join_quality": "exact",
      "notes": "Use geo_full_mapping for hierarchical drill-down queries"
    }
  ],
  "known_data_quality_issues": {
    "geography_master": {
      "description": "Multiple ontologies exist - LGD, ICDS, Poshan Tracker use different codes",
      "affected_tables": [
        "master_blocks",
        "master_villages",
        "anganwadi_centres"
      ],
      "mitigation": "Always use LGD codes (district_code_lgd, block_code_lgd) as canonical identifiers"
    },
    "awc_identity": {
      "description": "No single AWC identifier across systems; Poshan 11-digit code is most reliable",
      "affected_tables": [
        "anganwadi_centres"
      ],
      "mitigation": "Use name+block+district composite for matching when IDs unavailable"
    },
    "text_geography_fields": {
      "description": "mothers and anc_visits use TEXT district/block names. mothers has lgd_district_code so the district level can be joined exactly; block/village remain TEXT.",
      "affected_tables": [
        "mothers",
        "anc_visits"
      ],
      "mitigation": "Prefer mothers.lgd_district_code → master_districts.district_code_lgd for the district level. For block/village use UPPER(TRIM()) text matching, or prefer village_indicators_monthly for aggregations."
    }
  },
  "recommended_join_paths": {
    "village_level_aggregation": {
      "use_table": "village_indicators_monthly",
      "reason": "Pre-aggregated monthly counts; avoids expensive joins on raw records"
    },
    "district_comparison": {
      "path": [
        "village_indicators_monthly",
        "→",
        "master_districts"
      ],
      "join_on": "district_code_lgd"
    },
    "facility_coverage": {
      "path": [
        "master_health_facilities",
        "→",
        "master_blocks",
        "→",
        "master_districts"
      ],
      "join_on": [
        "block_code_lgd",
        "district_code_lgd"
      ]
    },
    "mother_app_pregnancy": {
      "path": [
        "mothers",
        "→",
        "mother_anc_visits_flat",
        "/",
        "mother_children"
      ],
      "join_on": [
        "mother_id",
        "pregnancy_number"
      ],
      "reason": "Composite-FK joins (enforced) — use these instead of mother_id alone, which is non-unique because one mother may have multiple pregnancies."
    }
  }
}